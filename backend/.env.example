# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./anamnesis.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/anamnesis_ai
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_CONNECT_TIMEOUT=5

# ── LLM Providers (set ONE of the following) ─────────────────────────────────
# GEMINI_API_KEY=your_key_here
# GEMINI_MODEL=gemini-1.5-flash
ANTHROPIC_API_KEY=your_key_here
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# ANTHROPIC_MAX_TOKENS=1024

# ── CORS ──────────────────────────────────────────────────────────────────────
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Application ───────────────────────────────────────────────────────────────
# APP_ENV=development
# LOG_LEVEL=INFO
# LOG_FORMAT=text
# MAX_INPUT_LENGTH=2000
# MAX_CONCURRENT_SIMULATIONS=10
# CRITIC_CONFIDENCE_THRESHOLD=75
# CRITIC_MAX_ITERATIONS=2

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# CHROMA_DB_PATH=./chroma_db
